<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Items" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Ready" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Item name" />
        <EditText android:id="@+id/etItemName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Item name" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Description" />
        <EditText android:id="@+id/etItemDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Description" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Topics" />
        <EditText android:id="@+id/etItemTopics" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Topics (comma separated)" />
        <Button android:id="@+id/btnAddItem" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Add Item" />
        <Button android:id="@+id/btnRefreshItems" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Refresh" />
        <TextView android:id="@+id/tvOutput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:textIsSelectable="true" android:typeface="monospace" />
    </LinearLayout>
</ScrollView>
